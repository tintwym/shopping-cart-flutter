{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "installCommand": ":",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://shopping-cart-backend-slwz.onrender.com/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://shopping-cart-backend-slwz.onrender.com/images/:path*"
    },
    {
      "source": "/:path((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
